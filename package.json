{
  "name": "perchd",
  "version": "0.3.0",
  "description": "Single active dev-server switcher for git worktrees",
  "type": "module",
  "bin": {
    "perchd": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "worktree",
    "dev-server",
    "cli",
    "nextjs",
    "vite"
  ],
  "license": "MIT",
  "author": "Irwan Setiawan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/irwansetiawan/perchd.git"
  },
  "bugs": {
    "url": "https://github.com/irwansetiawan/perchd/issues"
  },
  "homepage": "https://github.com/irwansetiawan/perchd#readme",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "cac": "^6.7.14",
    "chokidar": "^5.0.0",
    "execa": "^9.5.0",
    "picocolors": "^1.1.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
